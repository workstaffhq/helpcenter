{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --host 0.0.0.0",
    "start-fr": "docusaurus start --host 0.0.0.0 --locale fr",
    "edit": "npm --prefix tools/visual-editor run edit",
    "edit:debug": "npm --prefix tools/visual-editor run edit:debug",
    "build": "docusaurus build",
    "build-next": "docusaurus build --config docusaurus.config.next.js",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --host 0.0.0.0",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@easyops-cn/docusaurus-search-local": "^0.55.0",
    "@mdx-js/react": "^3.1.1",
    "@svgr/webpack": "^8.1.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "^5.0.1",
    "react-share": "^5.2.2",
    "sass": "^1.97.3",
    "visual-editor": "file:tools/visual-editor"
  },
  "devDependencies": {
    "prettier": "2.7.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
